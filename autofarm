local function switchTab(name)
    if activeTab == name then return end
    
    local oldBtn = tabButtons[activeTab]
    local newBtn = tabButtons[name]
    activeTab = name
    
    TweenService:Create(oldBtn, TweenInfo_new(0.2), {
        BackgroundColor3 = Color3_fromRGB(18, 18, 22),
        BackgroundTransparency = 1,
        TextColor3 = Color3_fromRGB(160, 160, 170)
    }):Play()
    oldBtn.Font = Enum.Font.GothamSemibold
    
    TweenService:Create(newBtn, TweenInfo_new(0.2), {
        BackgroundColor3 = Color3_fromRGB(0, 220, 255),
        BackgroundTransparency = 0,
        TextColor3 = Color3_fromRGB(12, 12, 16)
    }):Play()
    newBtn.Font = Enum.Font.GothamBold
    
    for pageName, pageFrame in pairs(pages) do
        pageFrame.Visible = (pageName == name)
    end
end


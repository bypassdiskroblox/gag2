local seedCheckboxes = {}

local function createSeedCheckbox(parent, seedName)
    local itemFrame = Instance_new("TextButton")
    itemFrame.Name = seedName
    itemFrame.Size = UDim2_new(1, 0, 1, 0)
    itemFrame.BackgroundColor3 = Color3_fromRGB(18, 18, 22)
    itemFrame.BackgroundTransparency = 0.2
    itemFrame.Text = ""
    itemFrame.AutoButtonColor = false
    
    local corner = Instance_new("UICorner")
    corner.CornerRadius = UDim_new(0, 6)
    corner.Parent = itemFrame
    
    local stroke = Instance_new("UIStroke")
    stroke.Color = Color3_fromRGB(35, 35, 45)
    stroke.Thickness = 1
    stroke.Parent = itemFrame
    
    local label = Instance_new("TextLabel")
    label.Size = UDim2_new(1, -32, 1, 0)
    label.Position = UDim2_new(0, 8, 0, 0)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamMedium
    label.Text = seedName
    label.TextColor3 = Color3_fromRGB(180, 180, 190)
    label.TextSize = 11
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = itemFrame
    
    local indicator = Instance_new("Frame")
    indicator.Size = UDim2_new(0, 14, 0, 14)
    indicator.Position = UDim2_new(1, -22, 0.5, -7)
    indicator.BackgroundColor3 = Color3_fromRGB(45, 45, 50)
    indicator.Parent = itemFrame
    
    local indCorner = Instance_new("UICorner")
    indCorner.CornerRadius = UDim_new(0, 3)
    indCorner.Parent = indicator
    
    local indStroke = Instance_new("UIStroke")
    indStroke.Color = Color3_fromRGB(55, 55, 65)
    indStroke.Thickness = 1
    indStroke.Parent = indicator
    
    local function updateVisual(selected)
        if selected then
            TweenService:Create(indicator, TweenInfo_new(0.15), {BackgroundColor3 = Color3_fromRGB(0, 220, 255)}):Play()
            TweenService:Create(label, TweenInfo_new(0.15), {TextColor3 = Color3_fromRGB(255, 255, 255)}):Play()
            stroke.Color = Color3_fromRGB(0, 220, 255)
        else
            TweenService:Create(indicator, TweenInfo_new(0.15), {BackgroundColor3 = Color3_fromRGB(45, 45, 50)}):Play()
            TweenService:Create(label, TweenInfo_new(0.15), {TextColor3 = Color3_fromRGB(180, 180, 190)}):Play()
            stroke.Color = Color3_fromRGB(35, 35, 45)
        end
    end
    
    itemFrame.MouseButton1Click:Connect(function()
        _G.SelectedSeeds[seedName] = not _G.SelectedSeeds[seedName]
        updateVisual(_G.SelectedSeeds[seedName])
    end)
    
    itemFrame.MouseEnter:Connect(function()
        if not _G.SelectedSeeds[seedName] then
            TweenService:Create(stroke, TweenInfo_new(0.15), {Color = Color3_fromRGB(100, 100, 110)}):Play()
        end
    end)
    itemFrame.MouseLeave:Connect(function()
        if not _G.SelectedSeeds[seedName] then
            TweenService:Create(stroke, TweenInfo_new(0.15), {Color = Color3_fromRGB(35, 35, 45)}):Play()
        end
    end)
    
    itemFrame.Parent = parent
    
    local cbObj = {
        Update = function(val)
            _G.SelectedSeeds[seedName] = val
            updateVisual(val)
        end
    }
    seedCheckboxes[seedName] = cbObj
end

for _, seed in ipairs(RestockSeeds) do
    createSeedCheckbox(BuyScroll, seed)
end

SelectAllBtn.MouseButton1Click:Connect(function()

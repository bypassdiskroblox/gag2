local function isSeedNameInText(seedName, text)
    local lowerText = text:lower()
    local trans = SeedTranslations[seedName]
    if trans then
        for _, term in ipairs(trans) do
            if lowerText:find(term) then
                return true
            end
        end
    end
    local cleanSeed = cleanString(seedName)
    local cleanText = cleanString(text)
    return cleanText:find(cleanSeed) ~= nil
end

local function findSeedFrame(seedName)
    local shop = game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("SeedShop")
    if not shop then return nil end
    local normalShop = shop:FindFirstChild("Frame") and shop.Frame:FindFirstChild("NormalShop")
    if not normalShop then return nil end
    
    local targetClean = cleanString(seedName)
    local frame = normalShop:FindFirstChild(seedName)
    if frame then return frame end
    
    for _, child in ipairs(normalShop:GetChildren()) do
        if cleanString(child.Name) == targetClean then
            return child
        end
    end
    
    for _, child in ipairs(normalShop:GetChildren()) do
        local childClean = cleanString(child.Name)
        if childClean:match(targetClean) or targetClean:match(childClean) then
            return child
        end
    end
    return nil
end

local function activateGuiObject(obj)
    if not obj then return end
    
    pcall(function()
        local vim = game:GetService("VirtualInputManager")
        local absPos = obj.AbsolutePosition
        local absSize = obj.AbsoluteSize
        local center = absPos + (absSize / 2)
        vim:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 1)
        task.wait(0.02)
        vim:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 1)
    end)
    
    pcall(function()
        if firesignal then
            firesignal(obj.Activated)
        end
    end)
    pcall(function()
        for _, conn in ipairs(getconnections(obj.Activated)) do
            conn:Fire()
        end
    end)
    
    pcall(function()
        if firesignal then
            firesignal(obj.MouseButton1Click)
        end
    end)
    pcall(function()
        for _, conn in ipairs(getconnections(obj.MouseButton1Click)) do
            conn:Fire()
        end
    end)
    
    pcall(function()
        if firesignal then
            firesignal(obj.MouseButton1Down)
            firesignal(obj.MouseButton1Up)
        end
    end)
    
    pcall(function()
        if firesignal then
            local mockInputBegan = {
                UserInputType = Enum.UserInputType.MouseButton1,
                UserInputState = Enum.UserInputState.Begin,
                Position = Vector3_new(0, 0, 0)
            }
            local mockInputEnded = {
                UserInputType = Enum.UserInputType.MouseButton1,
                UserInputState = Enum.UserInputState.End,
                Position = Vector3_new(0, 0, 0)
            }
            firesignal(obj.InputBegan, mockInputBegan)
            firesignal(obj.InputEnded, mockInputEnded)
        end
    end)
    
    pcall(function()
        local mockInputBegan = {
            UserInputType = Enum.UserInputType.MouseButton1,
            UserInputState = Enum.UserInputState.Begin,
            Position = Vector3_new(0, 0, 0)
        }
        for _, conn in ipairs(getconnections(obj.InputBegan)) do
            conn:Fire(mockInputBegan)
        end
    end)
end

local function activateSeedCard(seedFrame)
    if not seedFrame then return end
    
    local textButton = seedFrame:FindFirstChild("TextButton")
    if textButton and textButton:IsA("GuiButton") then
        activateGuiObject(textButton)
        return
    end
    
    for _, desc in ipairs(seedFrame:GetDescendants()) do
        if desc:IsA("GuiButton") then
            activateGuiObject(desc)
            return
        end
    end
    
    local mainFrame = seedFrame:FindFirstChild("Main_Frame")
    if mainFrame then
        activateGuiObject(mainFrame)
    else
        activateGuiObject(seedFrame)
    end
end

local function findBuyButton()
    local shop = game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("SeedShop")
    if not shop then return nil end
    
    local normalShop = shop:FindFirstChild("Frame") and shop.Frame:FindFirstChild("NormalShop")
    if not normalShop then return nil end
    
    local buyButton = nil
    pcall(function()
        buyButton = normalShop.Sheckles_Shelf.Main_Frame.Buttons.BuyButton
    end)
    if buyButton then return buyButton end
    
    for _, desc in ipairs(normalShop:GetDescendants()) do
        if desc.Name == "BuyButton" and desc:IsA("GuiButton") then
            return desc
        end
    end
    return nil
end

local function isNoStock(normalShop)
    local shecklesShelf = normalShop:FindFirstChild("Sheckles_Shelf")
    if not shecklesShelf then return false end
    
    for _, desc in ipairs(shecklesShelf:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            local txt = desc.Text:upper()
            if txt:match("NO STOCK") or txt:match("OUT OF STOCK") or txt:match("НЕТ В НАЛИЧИИ") then
                return true
            end
        end
    end
    return false
end

local function getShelfText()
    local shop = game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("SeedShop")
    local normalShop = shop and shop:FindFirstChild("Frame") and shop.Frame:FindFirstChild("NormalShop")
    local shecklesShelf = normalShop and normalShop:FindFirstChild("Sheckles_Shelf")
    if not shecklesShelf then return "" end
    
    local combinedText = ""
    for _, desc in ipairs(shecklesShelf:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            combinedText = combinedText .. desc.Text .. "|"
        end
    end
    return combinedText
end

local function isSeedSelected(seedName)
    return isSeedNameInText(seedName, getShelfText())
end

local function scrollToFrame(scrollingFrame, targetFrame)
    if not scrollingFrame or not targetFrame then return end
    pcall(function()
        if scrollingFrame:IsA("ScrollingFrame") then
            local relativeY = targetFrame.AbsolutePosition.Y - scrollingFrame.AbsolutePosition.Y + scrollingFrame.CanvasPosition.Y
            scrollingFrame.CanvasPosition = Vector2_new(scrollingFrame.CanvasPosition.X, relativeY - 25)
            task.wait(0.1)
        end
    end)
end

local function ensureShopOpen()
    local shop = game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("SeedShop")
    if shop then
        pcall(function()
            if not shop.Enabled then
                shop.Enabled = true
            end
            if shop:FindFirstChild("Frame") and not shop.Frame.Visible then
                shop.Frame.Visible = true
            end
        end)
    end
end

local function closeShop()
    local shop = game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("SeedShop")
    if shop then
        pcall(function()
            shop.Enabled = false
            if shop:FindFirstChild("Frame") then
                shop.Frame.Visible = false
            end
        end)
    end
end

local function getPlayerCoins()
    local coins = 9e9
    pcall(function()
        local gui = game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")
        local target = gui.HUD.Currencies.CoinsCounter.Target
        if target:IsA("ValueBase") then
            coins = tonumber(target.Value) or 9e9
        elseif target:IsA("TextLabel") or target:IsA("TextButton") then
            local clean = target.Text:gsub("[^%d%.]", "")
            coins = tonumber(clean) or 9e9
        else
            local val = target:FindFirstChild("Value") or target.Value or target.Text
            local clean = tostring(val):gsub("[^%d%.]", "")
            coins = tonumber(clean) or 9e9
        end
    end)
    return coins
end

local function buySeed(seedName)
    local seedFrame = findSeedFrame(seedName)
    if not seedFrame then return end
    
    local stockTextObj = seedFrame:FindFirstChild("Stock_Text", true)
    if stockTextObj and stockTextObj:IsA("TextLabel") then
        local txt = stockTextObj.Text:lower()
        if txt:find("x0") or txt:find("0 in stock") or txt:find("нет в наличии") or txt:find("0 шт") then
            return
        end
    end
    
    local costTextObj = seedFrame:FindFirstChild("Cost_Text", true)
    if costTextObj and costTextObj:IsA("TextLabel") then
        local price = tonumber(costTextObj.Text:gsub("[^%d%.]", ""))
        if price then
            local currentCoins = getPlayerCoins()
            if price > currentCoins then
                return
            end
        end
    end
    
    ensureShopOpen()
    task.wait(0.1)
    
    local shop = game:GetService("Players").LocalPlayer.PlayerGui:FindFirstChild("SeedShop")
    local normalShop = shop and shop:FindFirstChild("Frame") and shop.Frame:FindFirstChild("NormalShop")
    if normalShop and normalShop:IsA("ScrollingFrame") then
        scrollToFrame(normalShop, seedFrame)
    end
    
    local oldText = getShelfText()
    activateSeedCard(seedFrame)
    
    local updated = false
    for i = 1, 8 do
        if not _G.AutoBuySeeds or not _G.PrivateProjectActive then return end
        task.wait(0.05)
        if getShelfText() ~= oldText then
            updated = true
            break
        end
    end
    
    local selected = updated or isSeedSelected(seedName)
    if selected and isNoStock(normalShop) then
        notify("No Stock", seedName .. " нет в наличии! Переход...", 1.5)
        return
    end
    
    local buyButton = findBuyButton()
    if not buyButton then return end
    
    for i = 1, 10 do
        if not _G.AutoBuySeeds or not _G.PrivateProjectActive then return end
        if isNoStock(normalShop) then
            notify("No Stock", seedName .. " закончился! Переход...", 1.5)
            break
        end
        activateGuiObject(buyButton)
        task.wait(0.05)
    end
end


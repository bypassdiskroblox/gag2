local activeNotification
local function notify(title, content, duration)
    duration = duration or 3
    if activeNotification then
        pcall(function() activeNotification:Destroy() end)
    end
    
    local notificationFrame = Instance_new("Frame")
    activeNotification = notificationFrame
    notificationFrame.Size = UDim2_new(0, 260, 0, 65)
    notificationFrame.Position = UDim2_new(1, 10, 1, -80)
    notificationFrame.BackgroundColor3 = Color3_fromRGB(12, 12, 16)
    notificationFrame.BackgroundTransparency = 0.15
    notificationFrame.BorderSizePixel = 0
    
    local uicorner = Instance_new("UICorner")
    uicorner.CornerRadius = UDim_new(0, 8)
    uicorner.Parent = notificationFrame
    
    local uistroke = Instance_new("UIStroke")
    uistroke.Color = Color3_fromRGB(0, 220, 255)
    uistroke.Thickness = 1
    uistroke.Parent = notificationFrame
    
    local titleLabel = Instance_new("TextLabel")
    titleLabel.Size = UDim2_new(1, -20, 0, 22)
    titleLabel.Position = UDim2_new(0, 12, 0, 6)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 13
    titleLabel.TextColor3 = Color3_fromRGB(255, 255, 255)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Text = title
    titleLabel.Parent = notificationFrame
    
    local contentLabel = Instance_new("TextLabel")
    contentLabel.Size = UDim2_new(1, -20, 0, 30)
    contentLabel.Position = UDim2_new(0, 12, 0, 26)
    contentLabel.BackgroundTransparency = 1
    contentLabel.Font = Enum.Font.GothamMedium
    contentLabel.TextSize = 11
    contentLabel.TextColor3 = Color3_fromRGB(170, 170, 180)
    contentLabel.TextXAlignment = Enum.TextXAlignment.Left
    contentLabel.TextWrapped = true
    contentLabel.Text = content
    contentLabel.Parent = notificationFrame
    
    notificationFrame.Parent = ScreenGui
    
    local slideInPos = UDim2_new(1, -280, 1, -90)
    TweenService:Create(notificationFrame, TweenInfo_new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = slideInPos}):Play()
    
    task.delay(duration, function()
        if notificationFrame and notificationFrame.Parent then
            local slideOutPos = UDim2_new(1, 10, 1, -90)
            local tween = TweenService:Create(notificationFrame, TweenInfo_new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Position = slideOutPos})
            tween:Play()
            tween.Completed:Connect(function()
                notificationFrame:Destroy()
                if activeNotification == notificationFrame then
                    activeNotification = nil
                end
            end)
        end
    end)
end

local myPlot = nil

local function findMyPlot()
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return nil end
    
    local userIdStr = tostring(LocalPlayer.UserId)
    for _, plot in ipairs(gardens:GetChildren()) do
        if plot.Name:match("^Plot") or plot:FindFirstChild("Plants") then
            local owner = plot:FindFirstChild("Owner")
            if owner then
                if owner:IsA("ValueBase") then
                    if owner.Value == LocalPlayer or owner.Value == LocalPlayer.Name or tostring(owner.Value) == userIdStr then
                        return plot
                    end
                elseif owner:IsA("Player") and owner == LocalPlayer then
                    return plot
                end
            end
            
            for _, child in ipairs(plot:GetChildren()) do
                if child.Name:lower():match("owner") or child.Name:lower():match("player") then
                    if child:IsA("ValueBase") then
                        if child.Value == LocalPlayer or child.Value == LocalPlayer.Name or tostring(child.Value) == userIdStr then
                            return plot
                        end
                    end
                end
            end
            
            for attrName, attrValue in pairs(plot:GetAttributes()) do
                if attrName:lower():match("owner") or attrName:lower():match("player") then
                    if attrValue == LocalPlayer.Name or tostring(attrValue) == userIdStr or attrValue == LocalPlayer then
                        return plot
                    end
                end
            end
            
            if plot.Name == LocalPlayer.Name or plot.Name == userIdStr then
                return plot
            end
        end
    end
    return nil
end

local function getMyPlot()
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return nil end
    
    if myPlot and myPlot.Parent == gardens then
        return myPlot
    end
    
    myPlot = findMyPlot()
    if myPlot then
        notify("Plot Cached", "Ваш плот успешно найден: " .. myPlot.Name, 3)
    end
    return myPlot
end

local originalCanCollide = {}

local function restoreCollisions()
    if next(originalCanCollide) ~= nil then
        pcall(function()
            for part, originalVal in pairs(originalCanCollide) do
                if part and part.Parent then
                    part.CanCollide = originalVal
                end
            end
        end)
        table.clear(originalCanCollide)
    end
end

local function countReadyFruits()
    local plot = getMyPlot()
    if not plot then return 0 end
    
    local count = 0
    local plants = plot:FindFirstChild("Plants")
    if plants then
        local function checkObject(obj)
            local harvestPart = obj:FindFirstChild("HarvestPart")
            if harvestPart then
                local prompt = harvestPart:FindFirstChild("HarvestPrompt") or harvestPart:FindFirstChildWhichIsA("ProximityPrompt")
                if prompt and prompt:IsA("ProximityPrompt") and prompt.Enabled then
                    count = count + 1
                end
            end
        end
        
        for _, plant in ipairs(plants:GetChildren()) do
            checkObject(plant)
            local fruitsFolder = plant:FindFirstChild("Fruits")
            if fruitsFolder then
                for _, fruit in ipairs(fruitsFolder:GetChildren()) do
                    checkObject(fruit)
                end
            end
        end
    end
    return count
end

local function harvestObject(obj, rootPart)
    local harvestPart = obj:FindFirstChild("HarvestPart")
    if harvestPart then
        local prompt = harvestPart:FindFirstChild("HarvestPrompt") or harvestPart:FindFirstChildWhichIsA("ProximityPrompt")
        if prompt and prompt:IsA("ProximityPrompt") and prompt.Enabled then
            pcall(function() rootPart.AssemblyLinearVelocity = Vector3_new(0, 0, 0) end)
            rootPart.CFrame = harvestPart.CFrame * CFrame_new(0, 1.5, 0)
            task.wait(0.04)
            
            if prompt.Enabled then
                fireproximityprompt(prompt)
            end
            return true
        end
    end
    return false
end


local myPlot = nil

local function findMyPlot()
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return nil end
    
    for _, plot in ipairs(gardens:GetChildren()) do
        if plot.Name:match("^Plot") or plot:FindFirstChild("Plants") then
            local owner = plot:FindFirstChild("Owner")
            if owner then
                if owner:IsA("ValueBase") then
                    if owner.Value == LocalPlayer or owner.Value == LocalPlayer.Name or tostring(owner.Value) == tostring(LocalPlayer.UserId) then
                        return plot
                    end
                elseif owner:IsA("Player") and owner == LocalPlayer then
                    return plot
                end
            end
            
            for _, child in ipairs(plot:GetChildren()) do
                if child.Name:lower():match("owner") or child.Name:lower():match("player") then
                    if child:IsA("ValueBase") then
                        if child.Value == LocalPlayer or child.Value == LocalPlayer.Name or tostring(child.Value) == tostring(LocalPlayer.UserId) then
                            return plot
                        end
                    end
                end
            end
            
            for attrName, attrValue in pairs(plot:GetAttributes()) do
                if attrName:lower():match("owner") or attrName:lower():match("player") then
                    if attrValue == LocalPlayer.Name or tostring(attrValue) == tostring(LocalPlayer.UserId) or attrValue == LocalPlayer then
                        return plot
                    end
                end
            end
            
            if plot.Name == LocalPlayer.Name or plot.Name == tostring(LocalPlayer.UserId) then
                return plot
            end
        end
    end
    
    return nil
end

local function getMyPlot()
    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then return nil end
    
    if myPlot and myPlot.Parent == gardens then
        return myPlot
    end
    
    myPlot = findMyPlot()
    if myPlot then
        notify("Plot Cached", "Ваш плот успешно найден: " .. myPlot.Name, 3)
    end
    return myPlot
end

local function harvestObject(obj, rootPart)
    local harvestPart = obj:FindFirstChild("HarvestPart")
    if harvestPart then
        local prompt = harvestPart:FindFirstChild("HarvestPrompt") or harvestPart:FindFirstChildWhichIsA("ProximityPrompt")
        if prompt and prompt:IsA("ProximityPrompt") and prompt.Enabled then
            pcall(function() rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end)
            rootPart.CFrame = harvestPart.CFrame * CFrame.new(0, 1.5, 0)
            task.wait(0.15)
            
            if prompt.Enabled then
                fireproximityprompt(prompt)
                task.wait(0.05)
            end
            return true
        end
    end
    return false
end

task.spawn(function()
    while _G.PrivateProjectActive do
        task.wait(0.5)
        
        if _G.AutoHarvest then
            local character = LocalPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            
            if rootPart then
                _G.IsHarvesting = true
                pcall(function() rootPart.Anchored = true end)
                
                pcall(function()
                    local plot = getMyPlot()
                    if plot then
                        local plants = plot:FindFirstChild("Plants")
                        if plants then
                            local originalCFrame = rootPart.CFrame
                            local teleported = false
                            
                            for _, plant in ipairs(plants:GetChildren()) do
                                if not _G.AutoHarvest or not _G.PrivateProjectActive then break end
                                
                                local plantHarvested = harvestObject(plant, rootPart)
                                if plantHarvested then
                                    teleported = true
                                end
                                
                                local fruitsFolder = plant:FindFirstChild("Fruits")
                                if fruitsFolder then
                                    for _, fruit in ipairs(fruitsFolder:GetChildren()) do
                                        if not _G.AutoHarvest or not _G.PrivateProjectActive then break end
                                        
                                        local fruitHarvested = harvestObject(fruit, rootPart)
                                        if fruitHarvested then
                                            teleported = true
                                        end
                                    end
                                end
                            end
                            
                            if teleported and _G.AutoHarvest and rootPart and rootPart.Parent then
                                pcall(function() rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end)
                                rootPart.CFrame = originalCFrame
                                task.wait(0.1)
                            end
                        end
                    end
                end)
                
                pcall(function() rootPart.Anchored = false end)
                _G.IsHarvesting = false
            end
        end
    end
end)

